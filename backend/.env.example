# Core Django / database
DEBUG=True
DJANGO_SECRET_KEY=change-me-local-dev-key
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432
DJANGO_DB_NAME=crm3
DJANGO_DB_USER=crm3
DJANGO_DB_PASSWORD=crm3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000

# Entrypoint bootstrap
DJANGO_SUPERUSER_USERNAME=crmadmin
DJANGO_SUPERUSER_EMAIL=admin@crm3.local
DJANGO_SUPERUSER_PASSWORD=admin123

# Public URLs / frontend integration
CRM_PUBLIC_URL=http://localhost

# AI provider (same contract as production code)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=gpt-4o-mini
AI_POLICY_PROMPT=
AI_DOCUMENT_PROMPT=
GUNICORN_TIMEOUT=300
CALCULATION_RECOGNITION_BUDGET_SECONDS=240
POLICY_RECOGNITION_VISION_FALLBACK_ENABLED=true
POLICY_RECOGNITION_PDF_RENDER_DPI=180
POLICY_RECOGNITION_MAX_VISION_PAGES=6

# Open Notebook
OPEN_NOTEBOOK_API_URL=
OPEN_NOTEBOOK_PASSWORD=
OPEN_NOTEBOOK_TIMEOUT_SECONDS=300
OPEN_NOTEBOOK_EMBED_ON_UPLOAD=true
OPEN_NOTEBOOK_CONTEXT_LEVEL=full content
OPEN_NOTEBOOK_MEDIA_ROOT=/app/media

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_REMINDER_INTERVAL=300
TELEGRAM_LINK_CODE_TTL_MINUTES=10

# Google Drive OAuth
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_DOCUMENT_LIBRARY_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN_FILE=/run/crm3-secrets/google_drive_oauth_refresh_token
GOOGLE_DRIVE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost/api/v1/notifications/settings/drive-callback/
GOOGLE_DRIVE_RECONNECT_ALLOWED_USER_ID=4
GOOGLE_DRIVE_RECONNECT_ALLOWED_USERNAME=Vova
GOOGLE_DRIVE_RECONNECT_SUCCESS_URL=http://localhost/settings
GOOGLE_DRIVE_OAUTH_POST_UPDATE_COMMAND=

# Mailcow
MAILCOW_API_URL=
MAILCOW_API_KEY=
MAILCOW_DOMAIN=
MAILCOW_IMAP_HOST=
MAILCOW_IMAP_PORT=993
MAILCOW_IMAP_MASTER_USER=
MAILCOW_IMAP_MASTER_PASS=

# Local feature toggles
DEAL_PIN_LIMIT=5
DEAL_TIME_TRACKING_ENABLED=true
DEAL_TIME_TRACKING_TICK_SECONDS=10
DEAL_TIME_TRACKING_CONFIRM_INTERVAL_SECONDS=600

# Optional issuance integration
SBER_ISSUANCE_LOGIN=
SBER_ISSUANCE_PASSWORD=
SBER_ISSUANCE_BASE_URL=https://auto.sberbankins.ru/PO.Insurance/ru.lois.web.POInsurance/POInsurance.html
