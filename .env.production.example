# Backend Django Settings
DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-random-secure-key-in-production
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432
POSTGRES_HOST_PORT=5435
DJANGO_DB_NAME=crm3
DJANGO_DB_USER=crm3
DJANGO_DB_PASSWORD=change-this-password-in-production
ALLOWED_HOSTS=173.249.7.183,zoom78.com,www.zoom78.com,mail.zoom78.com
CORS_ALLOWED_ORIGINS=https://zoom78.com,https://www.zoom78.com
CSRF_TRUSTED_ORIGINS=https://zoom78.com,https://www.zoom78.com

# Frontend Settings
VITE_API_URL=https://zoom78.com/api/v1
VITE_TELEGRAM_BOT_USERNAME=

# Docker Build Tag
IMAGE_TAG=latest

# Django superuser that entrypoint now enforces
DJANGO_SUPERUSER_USERNAME=crmadmin
DJANGO_SUPERUSER_EMAIL=admin@crm3.local
DJANGO_SUPERUSER_PASSWORD=replace-with-your-secret

# Настройки OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=gpt-4o-mini
POLICY_RECOGNITION_VISION_FALLBACK_ENABLED=true
POLICY_RECOGNITION_PDF_RENDER_DPI=180
POLICY_RECOGNITION_MAX_VISION_PAGES=6

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_REMINDER_INTERVAL=300
TELEGRAM_LINK_CODE_TTL_MINUTES=10
CRM_PUBLIC_URL=

# Mailcow integration
MAILCOW_API_URL=http://nginx-mailcow:8080/api/v1
MAILCOW_API_KEY=
MAILCOW_DOMAIN=zoom78.com
MAILCOW_IMAP_HOST=mail.zoom78.com
MAILCOW_IMAP_PORT=993
MAILCOW_IMAP_MASTER_USER=
MAILCOW_IMAP_MASTER_PASS=

# Google Drive integration
# Для production reconnect через UI обновляет refresh token в token file.
# Backup и backend должны смотреть на один и тот же token file.
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN_FILE=/run/crm3-secrets/google_drive_oauth_refresh_token
GOOGLE_DRIVE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_DOCUMENT_LIBRARY_FOLDER_ID=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=https://zoom78.com/api/v1/notifications/settings/drive-callback/
GOOGLE_DRIVE_RECONNECT_ALLOWED_USER_ID=4
GOOGLE_DRIVE_RECONNECT_ALLOWED_USERNAME=Vova
GOOGLE_DRIVE_RECONNECT_SUCCESS_URL=https://zoom78.com/settings
GOOGLE_DRIVE_OAUTH_POST_UPDATE_COMMAND=

# Sber policy issuance
SBER_ISSUANCE_LOGIN=
SBER_ISSUANCE_PASSWORD=
SBER_ISSUANCE_BASE_URL=https://auto.sberbankins.ru/PO.Insurance/ru.lois.web.POInsurance/POInsurance.html
SBER_ISSUANCE_PROFILE_DIR=
SBER_ISSUANCE_HEADLESS=false
SBER_ISSUANCE_MANUAL_TIMEOUT_SECONDS=900
SBER_ISSUANCE_VNC_HINT=
SBER_ISSUANCE_WORKDIR=
